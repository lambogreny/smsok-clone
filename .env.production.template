# ============================================
# SMSOK Clone — Production Environment
# Copy to .env on server: cp .env.production.template .env
# Generate JWT: openssl rand -hex 32
# ============================================

# --- Database ---
DATABASE_URL="postgresql://smsok:CHANGE_ME@postgres:5432/smsok"
DB_USER=smsok
DB_PASSWORD=CHANGE_ME
DB_NAME=smsok

# --- Redis ---
REDIS_URL="redis://redis:6379"

# --- Auth (REQUIRED — min 32 chars in production) ---
JWT_SECRET="CHANGE_ME_RUN_openssl_rand_hex_32"
CRON_SECRET="CHANGE_ME_RUN_openssl_rand_hex_24"
OTP_HASH_SECRET="CHANGE_ME_RUN_openssl_rand_hex_32"

# --- SMTP / Email ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM="SMSOK Clone <no-reply@your-domain.com>"
SMTP_SECURE=false

# --- EasyThunder SMS Gateway ---
SMS_API_URL=https://sms-api.cl1.easythunder.com
SMS_API_USERNAME=CHANGE_ME
SMS_API_PASSWORD=CHANGE_ME

# --- EasySlip Payment Verification ---
EASYSLIP_API_KEY=CHANGE_ME
EASYSLIP_API_URL=https://developer.easyslip.com/api/v1

# --- App ---
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NODE_ENV=production

# --- Auto-Deploy (Watchtower) ---
# Token for GitHub Actions to trigger immediate deploy
# Generate: openssl rand -hex 16
WATCHTOWER_TOKEN=CHANGE_ME
# Host docker login config for Watchtower to pull private GHCR images
DOCKER_CONFIG_PATH=/home/byteder/.docker/config.json
# Optional: notification URL (Slack, Discord, etc.)
# Format: https://containrrr.dev/shoutrrr/services/overview/
WATCHTOWER_NOTIFY_URL=
