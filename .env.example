# ============================================
# SMSOK Clone — Environment Variables
# Copy to .env: cp .env.example .env
# ============================================

# --- Database (REQUIRED) ---
DATABASE_URL="postgresql://smsok:smsok_dev_2026@localhost:5434/smsok?schema=public"

# --- Redis (REQUIRED for queues + rate limiting) ---
REDIS_URL="redis://localhost:6380"
# BullMQ uses separate host/port config:
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=  # optional for local dev

# --- Auth (REQUIRED) ---
JWT_SECRET="smsok-local-dev-secret-32chars-min"
OTP_HASH_SECRET="smsok-otp-dev-secret-32chars-minimum"
OTP_BYPASS_CODE=780900  # optional — dev only, leave empty in production

# --- App ---
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
COMMIT_SHA=dev
LOG_LEVEL=debug  # optional: debug, info, warn, error

# --- EasyThunder SMS Gateway (REQUIRED for SMS sending) ---
SMS_API_URL=https://sms-api.cl1.easythunder.com
SMS_API_USERNAME=  # REQUIRED in production
SMS_API_PASSWORD=  # REQUIRED in production

# --- EasySlip Payment Verification (optional) ---
EASYSLIP_API_KEY=
EASYSLIP_API_URL=https://developer.easyslip.com/api/v1

# --- Resend Email (optional — for notifications) ---
RESEND_API_KEY=
RESEND_FROM="SMSOK <noreply@smsok.io>"

# --- SMTP Email (alternative to Resend) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="SMSOK <no-reply@your-domain.com>"
# SMTP_SECURE=false

# --- 2FA Encryption (optional — for TOTP) ---
# TWO_FA_ENCRYPTION_KEY=  # openssl rand -hex 32

# --- Cron Jobs (optional) ---
# CRON_SECRET=  # openssl rand -hex 24

# --- NextAuth (optional — legacy compatibility) ---
# NEXTAUTH_SECRET=  # openssl rand -hex 32
# NEXTAUTH_URL=http://localhost:3000

# --- Sentry (optional — error tracking) ---
# NEXT_PUBLIC_SENTRY_DSN=  # https://xxx@sentry.io/xxx
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=  # for source map uploads

# --- Dev/Test API (optional — dev only, leave empty in production) ---
# DEV_SECRET=smsok-dev-secret-2026  # used by /api/dev/* endpoints (reset credits, etc.)

# --- Debug ---
# DEBUG_API_ERRORS=1  # show detailed API errors in dev

# ============================================
# Port Rule:
#   localhost:3000 = SMSOK Clone (main app)
#   localhost:3001 = Backoffice (bun run dev:admin)
# ============================================
