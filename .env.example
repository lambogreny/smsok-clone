DATABASE_URL="postgresql://user:password@localhost:5432/smsok?schema=public"
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32

# EasyThunder SMS API (DTAC Corporate Gateway)
SMS_API_URL=https://sms-api.cl1.easythunder.com
SMS_API_USERNAME=
SMS_API_PASSWORD=

# EasySlip API (Payment Slip Verification)
EASYSLIP_API_KEY=
EASYSLIP_API_URL=https://developer.easyslip.com/api/v1

# 2FA Encryption (MUST be different from JWT_SECRET)
TWO_FA_ENCRYPTION_KEY=CHANGE_ME_RUN_openssl_rand_hex_32

# OTP Security
OTP_HASH_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
# OTP bypass code for testing/support (dev/staging only, leave empty in production)
# MUST be exactly 6 digits if set — shorter codes are silently ignored by schema validation
OTP_BYPASS_CODE=

# Redis (BullMQ Queue System)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
