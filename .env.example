# ============================================
# SMSOK Clone — Environment Variables
# Copy to .env: cp .env.example .env
# ============================================

# --- Database (REQUIRED) ---
DATABASE_URL="postgresql://smsok:YOUR_DB_PASSWORD_HERE@localhost:5434/smsok?schema=public&connection_limit=10&pool_timeout=20"

# --- Redis (REQUIRED for queues + rate limiting) ---
REDIS_URL="redis://localhost:6380"
# BullMQ uses separate host/port config:
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=  # optional for local dev

# --- Auth (REQUIRED) ---
JWT_SECRET="YOUR_JWT_SECRET"
ADMIN_JWT_SECRET="YOUR_ADMIN_JWT_SECRET"
OTP_HASH_SECRET="YOUR_OTP_HASH_SECRET"
OTP_BYPASS_CODE=  # optional — dev only, leave empty in production

# --- App ---
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BACKOFFICE_APP_URL="http://localhost:3001"
COMMIT_SHA=dev
NEXT_PUBLIC_COMMIT_SHA=dev
LOG_LEVEL=debug  # optional: debug, info, warn, error
ADMIN_SEED_PASSWORD=  # REQUIRED when running prisma/seed.ts in production

# --- Public Branding / Payment Display ---
# NEXT_PUBLIC_BANK_NAME="ไทยพาณิชย์ (SCB)"
# NEXT_PUBLIC_BANK_COLOR="#4E2A84"
# NEXT_PUBLIC_BANK_ACCOUNT_NAME="นายภูมิชนะ อุดแก้ว"
# NEXT_PUBLIC_BANK_ACCOUNT_NUMBER="407-824-0476"

# --- EasyThunder SMS Gateway (REQUIRED for SMS sending) ---
SMS_API_URL=https://sms-api.cl1.easythunder.com
SMS_API_USERNAME=  # REQUIRED in production
SMS_API_PASSWORD=  # REQUIRED in production

# --- EasySlip Payment Verification (legacy — used by topup flow) ---
EASYSLIP_API_KEY=
EASYSLIP_API_URL=https://document.easyslip.com/documents/verify/bank/image

# --- SlipOK Payment Verification (REQUIRED for order payment) ---
SLIPOK_BRANCH_ID=
SLIPOK_API_KEY=
# KBANK_ACCOUNT=  # optional — accepted payer account alias for slip verification
# SCB_ACCOUNT=    # optional — accepted payer account alias for slip verification

# --- Document / Company Metadata ---
# COMPANY_NAME="บริษัท เอสเอ็มเอสโอเค จำกัด"
# COMPANY_TAX_ID="0105566000000"
# COMPANY_BRANCH="สำนักงานใหญ่"
# COMPANY_ADDRESS="123 อาคาร ABC ชั้น 10 ถ.สุขุมวิท แขวงคลองเตย เขตคลองเตย กรุงเทพฯ 10110"
# COMPANY_PHONE="LINE: @smsok"
# COMPANY_EMAIL="billing@smsok.com"
# DOCUMENT_VERIFY_BASE_URL="https://verify.smsok.co"
# NEXT_PUBLIC_DOCUMENT_VERIFY_BASE_URL="https://verify.smsok.co"
# SHORT_LINK_BASE_URL="https://go.smsok.co"

# --- Resend Email (optional — for notifications) ---
RESEND_API_KEY=
RESEND_FROM="SMSOK <noreply@smsok.io>"

# --- SMTP Email (alternative to Resend) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="SMSOK <no-reply@your-domain.com>"
# SMTP_SECURE=false

# --- 2FA Encryption (optional — for TOTP) ---
# TWO_FA_ENCRYPTION_KEY=  # openssl rand -hex 32

# --- Cron Jobs (optional) ---
# CRON_SECRET=  # openssl rand -hex 24

# --- NextAuth (optional — legacy compatibility) ---
# NEXTAUTH_SECRET=  # openssl rand -hex 32
# NEXTAUTH_URL=http://localhost:3000

# --- Sentry (optional — error tracking) ---
# NEXT_PUBLIC_SENTRY_DSN=  # https://xxx@sentry.io/xxx
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=  # for source map uploads

# --- Dev/Test API (optional — dev only, leave empty in production) ---
# DEV_SECRET=  # used by /api/dev/* endpoints (reset credits, etc.)
# E2E_DEV_SECRET=  # optional — dedicated secret for e2e helpers
# STOP_WEBHOOK_SECRET=  # optional — shared secret for /api/v1/webhooks/stop

# --- Cloudflare R2 (file storage — slips, docs) ---
# R2_ACCOUNT_ID=          # Cloudflare account ID
# R2_ACCESS_KEY_ID=       # R2 API token access key
# R2_SECRET_ACCESS_KEY=   # R2 API token secret
# R2_ENDPOINT=            # https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=              # primary R2 bucket used by app storage proxy
# R2_BUCKET_SLIPS=smsok-slips
# R2_BUCKET_DOCS=smsok-docs
# R2_PUBLIC_URL=          # https://cdn.smsok.io (optional — for public file access)

# --- Seed / Test Credentials (REQUIRED for prisma db seed + E2E tests) ---
SEED_PASSWORD=          # password for demo seed user
ADMIN_SEED_PASSWORD=    # password for admin seed users
QA_TEST_PASSWORD=       # password for QA test user
# SEED_EMAIL=           # optional — override seed user email
# SEED_PHONE=           # optional — override seed user phone

# --- E2E Test Credentials ---
E2E_USER_PASSWORD=      # password for E2E test user
E2E_ADMIN_PASSWORD=     # password for E2E admin user

# --- Test Environment Secrets ---
# TEST_DB_PASSWORD=     # used by .env.test
# TEST_JWT_SECRET=      # used by .env.test
# TEST_ADMIN_JWT_SECRET= # used by .env.test
# TEST_2FA_KEY=         # used by .env.test
# TEST_CRON_SECRET=     # used by .env.test

# --- Debug ---
# DEBUG_API_ERRORS=1  # show detailed API errors in dev

# ============================================
# Port Rule:
#   localhost:3000 = SMSOK Clone (main app)
#   localhost:3001 = Backoffice (bun run dev:admin)
# ============================================
