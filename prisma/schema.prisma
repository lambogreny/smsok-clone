  payAmount        Decimal            @map("pay_amount") @db.Decimal(12, 2)
  status           OrderStatus        @default(PENDING)
  expiresAt        DateTime           @map("expires_at")
  quotationNumber  String?            @unique @map("quotation_number")
  quotationUrl     String?            @map("quotation_url")
  invoiceNumber    String?            @unique @map("invoice_number")
  invoiceUrl       String?            @map("invoice_url")
  creditNoteNumber String?            @unique @map("credit_note_number")
  creditNoteUrl    String?            @map("credit_note_url")
  debitNoteNumber  String?            @unique @map("debit_note_number")
  debitNoteUrl     String?            @map("debit_note_url")
  slipUrl          String?            @map("slip_url")
  slipFileName     String?            @map("slip_file_name")
  slipFileSize     Int?               @map("slip_file_size")
  easyslipVerified Boolean?           @map("easyslip_verified")
  easyslipResponse Json?              @map("easyslip_response")
  whtCertUrl       String?            @map("wht_cert_url")
  whtCertVerified  Boolean?           @map("wht_cert_verified")
  adminNote        String?            @map("admin_note")
  rejectReason     String?            @map("reject_reason")
  reviewedBy       String?            @map("reviewed_by")
  reviewedAt       DateTime?          @map("reviewed_at")
  paidAt           DateTime?          @map("paid_at")
  completedAt      DateTime?          @map("completed_at")
  createdBy        String             @map("created_by")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
