  packageTierId    String             @map("package_tier_id")
  taxProfileId     String?            @map("tax_profile_id")
  orderNumber      String             @unique @map("order_number")
  customerType     OrderCustomerType  @map("customer_type")
  packageName      String             @map("package_name")
  smsCount         Int                @map("sms_count")
  taxName          String             @map("tax_name")
  taxId            String             @map("tax_id")
  taxAddress       String             @map("tax_address") @db.Text
  taxBranchType    OrderBranchType    @map("tax_branch_type")
  taxBranchNumber  String?            @map("tax_branch_number")
  netAmount        Decimal            @map("net_amount") @db.Decimal(12, 2)
