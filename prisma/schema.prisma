// ══════════════════════════════════════════════════════════

model ApiLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  method     String
  url        String
  reqHeaders String?  @map("req_headers")
  reqBody    String?  @map("req_body")
  resStatus  Int      @map("res_status")
  resBody    String?  @map("res_body")
  latencyMs  Int      @map("latency_ms")
  errorCode  String?  @map("error_code")
  errorMsg   String?  @map("error_msg")
  createdAt  DateTime @default(now()) @map("created_at")
  endpoint   String
  ipAddress  String?  @map("ip_address")
  stackTrace String?  @map("stack_trace")
  source     String   @default("API")
  apiKeyId   String?  @map("api_key_id")
  apiKey     ApiKey?  @relation(fields: [apiKeyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([apiKeyId])
  @@index([resStatus])
  @@index([endpoint])
  @@index([ipAddress])
  @@map("api_logs")
}

// ══════════════════════════════════════════════════════════
// PDPA Compliance
// ══════════════════════════════════════════════════════════

model Consent {
  id             String         @id @default(cuid())
  organizationId String?        @map("organization_id")
  contactId      String         @map("contact_id")
  purpose        ConsentPurpose
  granted        Boolean
  source         String         // "form", "api", "import", "sms"
  ipAddress      String?        @map("ip_address")
  evidence       String?        // reference to consent form/screenshot
  grantedAt      DateTime       @default(now()) @map("granted_at")
  revokedAt      DateTime?      @map("revoked_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization   Organization?  @relation(fields: [organizationId], references: [id])

  @@index([contactId, purpose])
  @@index([organizationId])
  @@map("consents")
}

model OptOutLog {
  id             String        @id @default(cuid())
  organizationId String?       @map("organization_id")
  contactId      String?       @map("contact_id")
  phone          String
  method         String        // "sms_reply", "link", "manual", "api"
  keyword        String?       // "STOP", "ยกเลิก" etc.
  processedAt    DateTime?     @map("processed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  contact        Contact?      @relation(fields: [contactId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([phone])
  @@index([organizationId])
  @@index([contactId])
  @@map("opt_out_logs")
}

model DataRequest {
  id             String            @id @default(cuid())
  organizationId String?           @map("organization_id")
  contactId      String?           @map("contact_id")
  type           DataRequestType
  requestorEmail String            @map("requestor_email")
  requestorPhone String?           @map("requestor_phone")
  status         DataRequestStatus @default(PENDING)
  processedBy    String?           @map("processed_by")
  notes          String?
  dueDate        DateTime          @map("due_date") // PDPA: must process within 30 days
  completedAt    DateTime?         @map("completed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  contact        Contact?          @relation(fields: [contactId], references: [id])
  organization   Organization?     @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status])
  @@index([status])
  @@index([dueDate])
  @@map("data_requests")
}

// ══════════════════════════════════════════════════════════
// Audit Logs (append-only, immutable)
// ══════════════════════════════════════════════════════════

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?       @map("organization_id")
  userId         String?       @map("user_id")
  action         String        // "message.send", "contact.delete", "member.invite", etc.
  resource       String        // "Message", "Contact", "Campaign", etc.
  resourceId     String?       @map("resource_id")
  metadata       Json?         // flexible payload
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  result         String        @default("success") // "success" | "failure"
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// ══════════════════════════════════════════════════════════
// Backoffice — Admin Users
// ══════════════════════════════════════════════════════════

model AdminUser {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  password       String
  role           AdminRole       @default(SUPPORT)
  isActive       Boolean         @default(true) @map("is_active")
  lastLogin      DateTime?       @map("last_login")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  refunds        Refund[]
  ticketReplies  TicketReply[]
  assignedTickets SupportTicket[] @relation("AssignedTickets")

  @@map("admin_users")
}

// ══════════════════════════════════════════════════════════
// Backoffice — Support: Tickets & Knowledge Base
// ══════════════════════════════════════════════════════════

model SupportTicket {
  id             String         @id @default(cuid())
  organizationId String?        @map("organization_id")
  userId         String?        @map("user_id")
  assigneeId     String?        @map("assignee_id")
  subject        String
  description    String
  status         TicketStatus     @default(OPEN)
  priority       TicketPriority   @default(MEDIUM)
  category       TicketCategory   @default(GENERAL)
  resolvedAt     DateTime?        @map("resolved_at")
  closedAt       DateTime?        @map("closed_at")
  firstReplyAt   DateTime?        @map("first_reply_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  replies        TicketReply[]
  assignee       AdminUser?       @relation("AssignedTickets", fields: [assigneeId], references: [id])

  @@index([userId, status])
  @@index([status, priority])
  @@index([assigneeId])
  @@index([organizationId])
  @@index([category])
  @@index([createdAt])
  @@map("support_tickets")
}

model TicketReply {
  id          String           @id @default(cuid())
  ticketId    String           @map("ticket_id")
  adminId     String?          @map("admin_id")
  userId      String?          @map("user_id")
  senderType  TicketSenderType @default(CUSTOMER)  @map("sender_type")
  content     String
  isInternal  Boolean          @default(false) @map("is_internal")
  createdAt   DateTime         @default(now()) @map("created_at")
  ticket      SupportTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  admin       AdminUser?       @relation(fields: [adminId], references: [id])
  attachments TicketAttachment[]

  @@index([ticketId, createdAt])
  @@map("ticket_replies")
}

model TicketAttachment {
  id        String      @id @default(cuid())
  replyId   String      @map("reply_id")
  fileName  String      @map("file_name")
  fileUrl   String      @map("file_url")
  fileSize  Int         @map("file_size")
  mimeType  String      @map("mime_type")
  createdAt DateTime    @default(now()) @map("created_at")
  reply     TicketReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@index([replyId])
  @@map("ticket_attachments")
}

model KnowledgeBase {
  id              String   @id @default(cuid())
  title           String
  content         String   @db.Text
  category        String   @default("general")
  slug            String   @unique
  published       Boolean  @default(false)
  publishedAt     DateTime? @map("published_at")
  searchCount     Int      @default(0) @map("search_count")
  viewCount       Int      @default(0) @map("view_count")
  helpfulCount    Int      @default(0) @map("helpful_count")
  notHelpfulCount Int      @default(0) @map("not_helpful_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([published])
  @@index([searchCount])
  @@map("knowledge_base")
}

// ══════════════════════════════════════════════════════════
// Backoffice — CTO: Alerts & Deployments
// ══════════════════════════════════════════════════════════

model Alert {
  id         String        @id @default(cuid())
  type       String        // "error_rate", "latency", "delivery_rate", "credit_low"
  severity   AlertSeverity @default(WARNING)
  message    String
  rule       Json?         // alert rule config
  isActive   Boolean       @default(true) @map("is_active")
  triggeredAt DateTime?    @map("triggered_at")
  resolvedAt DateTime?     @map("resolved_at")
  resolvedBy String?       @map("resolved_by")
  resolveNote String?      @map("resolve_note")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([isActive])
  @@index([severity])
  @@index([type])
  @@map("alerts")
}

model Deployment {
  id         String   @id @default(cuid())
  version    String
  commitHash String?  @map("commit_hash")
  deployedBy String   @map("deployed_by")
  status     String   @default("success") // success, failed, rollback
  changelog  String?
  duration   Int?     // seconds
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("deployments")
}

// ══════════════════════════════════════════════════════════
// Backoffice — Marketing: Promo Codes
// ══════════════════════════════════════════════════════════

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @map("discount_type") // "credits", "percent"
  discountValue Int       @map("discount_value")
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  minPurchase   Int?      @map("min_purchase")
  active        Boolean   @default(true)
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([code])
  @@index([active])
  @@map("promo_codes")
}

// ══════════════════════════════════════════════════════════
// Payment Integration
// ══════════════════════════════════════════════════════════

model Plan {
  id            String         @id @default(cuid())
  name          String         @unique // starter, business, enterprise
  displayName   String         @map("display_name")
  price         Int            // satang (e.g., 49900 = 499 THB)
  credits       Int            // monthly credits included
  interval      String         @default("monthly") // monthly, yearly
  maxSenders    Int            @default(5) @map("max_senders")
  features      Json?          // additional features as JSON
  active        Boolean        @default(true)
  sortOrder     Int            @default(0) @map("sort_order")
  createdAt     DateTime       @default(now()) @map("created_at")
  subscriptions Subscription[]

  @@index([active])
  @@map("plans")
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  organizationId   String?   @map("organization_id")
  planId           String    @map("plan_id")
  status           String    @default("active") // active, canceled, past_due, trialing
  scheduleId       String?   @unique @map("omise_schedule_id")
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd DateTime  @map("current_period_end")
  canceledAt       DateTime? @map("canceled_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id])
  organization     Organization? @relation(fields: [organizationId], references: [id])
  plan             Plan      @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  organizationId  String?   @map("organization_id")
  packageTierId   String?   @map("package_tier_id")
  amount          Int       // satang (pre-VAT)
  vatAmount       Int?      @map("vat_amount") // VAT 7% in satang
  totalAmount     Int?      @map("total_amount") // amount + vat in satang
  currency        String    @default("THB")
  method          String    @default("BANK_TRANSFER") // BANK_TRANSFER only
  status          String    @default("PENDING") // PENDING, PROCESSING, PENDING_REVIEW, COMPLETED, FAILED, REFUNDED, EXPIRED
  // Slip
  slipUrl         String?   @map("slip_url")
  slipFileName    String?   @map("slip_file_name")
  slipFileSize    Int?      @map("slip_file_size")
  // EasySlip verification
  easyslipVerified Boolean? @map("easyslip_verified")
  easyslipResponse Json?    @map("easyslip_response")
  easyslipAmount  Int?      @map("easyslip_amount") // amount detected from slip (satang)
  easyslipBank    String?   @map("easyslip_bank")
  easyslipDate    DateTime? @map("easyslip_date")
  // Admin review
  adminNote       String?   @map("admin_note")
  rejectReason    String?   @map("reject_reason")
  reviewedBy      String?   @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  // WHT 3%
  hasWht          Boolean   @default(false) @map("has_wht")
  whtCertUrl      String?   @map("wht_cert_url")
  whtCertVerified Boolean?  @map("wht_cert_verified")
  // Tax
  taxProfileId    String?   @map("tax_profile_id")
  taxProfile      TaxProfile? @relation(fields: [taxProfileId], references: [id])
  // Amounts
  netPayAmount    Int?      @map("net_pay_amount") // total - wht = amount customer transfers (satang)
  expiresAt       DateTime? @map("expires_at") // 24hr expiry; partial index idx_payment_expires maintained in SQL migration
  // Invoice
  invoiceNumber   String?   @map("invoice_number") // INV-YYYYMM-XXXX
  invoiceUrl      String?   @map("invoice_url")
  preInvoiceNumber String?  @map("pre_invoice_number") // QT-YYYYMM-XXXX
  preInvoiceUrl   String?   @map("pre_invoice_url")
  creditNoteNumber String?  @map("credit_note_number") // CN-YYYYMM-XXXX
  creditNoteUrl   String?   @map("credit_note_url")
  // Refund
  refundAmount    Int?      @map("refund_amount") // satang
  refundedAt      DateTime? @map("refunded_at")
  // References
  creditsAdded    Int?      @map("credits_added")
  transactionId   String?   @map("transaction_id")
  subscriptionId  String?   @map("subscription_id")
  paidAt          DateTime? @map("paid_at")
  // Legacy Omise fields (unused)
  chargeId        String?   @unique @map("omise_charge_id")
  paymentToken    String?   @map("omise_token")
  failureCode     String?   @map("failure_code")
  failureMessage  String?   @map("failure_message")
  metadata        Json?
  subtotal        Int?
  whtAmount       Int?      @map("wht_amount")
  netAmount       Int?      @map("net_amount")
  idempotencyKey  String?   @unique @map("idempotency_key")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])
  packageTier     PackageTier?  @relation(fields: [packageTierId], references: [id])
  history         PaymentHistory[]

  @@index([userId, createdAt])
  @@index([organizationId])
  @@index([status])
  @@index([chargeId])
  @@index([invoiceNumber])
  @@map("payments")
}

model PaymentHistory {
  id          String    @id @default(cuid())
  paymentId   String    @map("payment_id")
  fromStatus  String?   @map("from_status")
  toStatus    String    @map("to_status")
  changedBy   String?   @map("changed_by") // admin or "system"
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  payment     Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("payment_history")
}

model TaxProfile {
  id              String    @id @default(cuid())
  organizationId  String?   @map("organization_id")
  userId          String    @map("user_id")
  companyName     String    @map("company_name")
  taxId           String    @map("tax_id") // 13 digits
  address         String    @db.Text
  branchType      String    @default("HEAD") @map("branch_type") // HEAD or BRANCH
  branchNumber    String?   @map("branch_number")
  isDefault       Boolean   @default(true) @map("is_default")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  organization    Organization? @relation(fields: [organizationId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  payments        Payment[]
  orders          Order[]

  @@index([organizationId], map: "idx_tax_profile_org")
  @@index([userId])
  @@map("tax_profiles")
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ══════════════════════════════════════════════════════════
// Backoffice — Operations: SMS Providers & Delivery
// ══════════════════════════════════════════════════════════

model SmsProvider {
  id             String           @id @default(cuid())
  name           String           @unique // "easythunder", "thaibulksms", "twilio"
  displayName    String           @map("display_name")
  apiUrl         String           @map("api_url")
  credentials    Json             // encrypted credentials
  status         ProviderStatus   @default(ACTIVE)
  priority       Int              @default(0) // lower = higher priority
  costPerSms     Decimal          @map("cost_per_sms") @db.Decimal(6, 4)
  balance        Decimal?         @db.Decimal(12, 2)
  balanceAlert   Decimal?         @map("balance_alert") @db.Decimal(12, 2)
  dailyLimit     Int?             @map("daily_limit")
  dailySent      Int              @default(0) @map("daily_sent")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  failoverConfig FailoverConfig[]
  carrierRoutes  CarrierRoute[]
  deliveryReports DeliveryReport[]

  @@index([status, priority])
  @@map("sms_providers")
}

model FailoverConfig {
  id              String      @id @default(cuid())
  primaryId       String      @map("primary_id")
  secondaryId     String      @map("secondary_id")
  triggerThreshold Decimal    @map("trigger_threshold") @db.Decimal(5, 2) // delivery rate % below this triggers failover
  autoEnabled     Boolean     @default(true) @map("auto_enabled")
  createdAt       DateTime    @default(now()) @map("created_at")
  primary         SmsProvider @relation(fields: [primaryId], references: [id])

  @@unique([primaryId, secondaryId])
  @@map("failover_configs")
}

model CarrierRoute {
  id         String      @id @default(cuid())
  carrier    String      // "AIS", "DTAC", "TRUEMOVE", "NT"
  providerId String      @map("provider_id")
  priority   Int         @default(0)
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now()) @map("created_at")
  provider   SmsProvider @relation(fields: [providerId], references: [id])

  @@unique([carrier, providerId])
  @@index([carrier, active])
  @@map("carrier_routes")
}

model DeliveryReport {
  id          String      @id @default(cuid())
  messageId   String      @map("message_id")
  providerId  String      @map("provider_id")
  carrier     String?
  status      String      // "delivered", "failed", "pending", "expired"
  errorCode   String?     @map("error_code")
  errorDetail String?     @map("error_detail")
  latencyMs   Int?        @map("latency_ms")
  reportedAt  DateTime    @default(now()) @map("reported_at")
  provider    SmsProvider @relation(fields: [providerId], references: [id])

  @@index([providerId, reportedAt])
  @@index([messageId])
  @@index([status])
  @@index([carrier, status])
  @@map("delivery_reports")
}

model PhoneBlacklist {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String   // "spam", "invalid", "carrier_blocked"
  addedBy   String   @map("added_by") // admin user id
  createdAt DateTime @default(now()) @map("created_at")

  @@map("phone_blacklist")
}

// ══════════════════════════════════════════════════════════
// Backoffice — CFO: Refunds & Tax Reports
// ══════════════════════════════════════════════════════════

model Refund {
  id            String       @id @default(cuid())
  transactionId String       @map("transaction_id")
  userId        String       @map("user_id")
  amount        Decimal      @db.Decimal(12, 2)
  credits       Int          // credits to restore
  reason        String
  status        RefundStatus @default(PENDING)
  processedBy   String?      @map("processed_by")
  processedAt   DateTime?    @map("processed_at")
  refundRef     String?      @map("refund_ref") // payment gateway refund reference
  createdAt     DateTime     @default(now()) @map("created_at")
  admin         AdminUser?   @relation(fields: [processedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@index([transactionId])
  @@map("refunds")
}

model TaxReport {
  id            String   @id @default(cuid())
  type          String   // "monthly_vat", "monthly_wht", "annual"
  period        String   // "2026-03", "2026"
  totalRevenue  Decimal  @map("total_revenue") @db.Decimal(12, 2)
  totalVat      Decimal  @map("total_vat") @db.Decimal(12, 2)
  totalWht      Decimal  @map("total_wht") @db.Decimal(12, 2)
  netAmount     Decimal  @map("net_amount") @db.Decimal(12, 2)
  transactionCount Int   @map("transaction_count")
  data          Json     // detailed breakdown
  generatedAt   DateTime @default(now()) @map("generated_at")
  generatedBy   String?  @map("generated_by")

  @@unique([type, period])
  @@index([type, period])
  @@map("tax_reports")
}

// ══════════════════════════════════════════════════════════
