// ══════════════════════════════════════════════════════════
// Onboarding
// ══════════════════════════════════════════════════════════

model UserOnboarding {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  emailVerified     Boolean  @default(false) @map("email_verified")
  phoneVerified     Boolean  @default(false) @map("phone_verified")
  senderNameSet     Boolean  @default(false) @map("sender_name_set")
  contactsImported  Boolean  @default(false) @map("contacts_imported")
  testSmsSent       Boolean  @default(false) @map("test_sms_sent")
  toppedUp          Boolean  @default(false) @map("topped_up")
  firstCampaign     Boolean  @default(false) @map("first_campaign")
  completedAt       DateTime? @map("completed_at")
  bonusCredited     Boolean  @default(false) @map("bonus_credited")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id])

  @@map("user_onboarding")
}

// ══════════════════════════════════════════════════════════
// PDPA Consent Logging (Immutable — append only)
// ══════════════════════════════════════════════════════════

enum ConsentType {
  SERVICE
  MARKETING
  THIRD_PARTY
  COOKIE
}

enum ConsentAction {
  OPT_IN
  OPT_OUT
}

enum PolicyDocType {
  PRIVACY
  TERMS
  MARKETING
  COOKIE
}

model PdpaPolicy {
  id               String       @id @default(cuid())
  version          String       // 'v1.0', 'v2.0'
  type             PolicyDocType
  title            String
  content          String       @db.Text
  summary          String?      @db.Text
  requiresReconsent Boolean     @default(false) @map("requires_reconsent")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  createdBy        String?      @map("created_by")
  consentLogs      PdpaConsentLog[]
  creator          User?        @relation("PolicyCreator", fields: [createdBy], references: [id])

  @@unique([type, version])
  @@index([type, isActive])
  @@map("pdpa_policies")
}

model PdpaConsentLog {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  policyId    String        @map("policy_id")
  consentType ConsentType   @map("consent_type")
  action      ConsentAction
  ipAddress   String?       @map("ip_address")
  userAgent   String?       @map("user_agent") @db.Text
  metadata    Json?
  recordedAt  DateTime      @default(now()) @map("recorded_at")
  user        User          @relation(fields: [userId], references: [id])
  policy      PdpaPolicy    @relation(fields: [policyId], references: [id])

  @@index([userId, recordedAt])
  @@index([consentType, action])
  @@index([policyId])
  @@map("pdpa_consent_logs")
}

// ══════════════════════════════════════════════════════════
// Bank Accounts
// ══════════════════════════════════════════════════════════

model BankAccount {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  bankCode      String   @map("bank_code")       // e.g. "KBANK", "SCB", "BBL"
  bankName      String   @map("bank_name")        // e.g. "ธนาคารกสิกรไทย"
  accountNumber String   @map("account_number")
  accountName   String   @map("account_name")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("bank_accounts")
}

