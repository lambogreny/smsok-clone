generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String  @default("")
  name          String
  password      String
  credits             Int       @default(15)
  role                String    @default("user")
  emailVerified       Boolean   @default(false)
  phoneVerified       Boolean   @default(false) @map("phone_verified")
  mustChangePassword    Boolean   @default(false) @map("must_change_password")
  notificationsReadAt   DateTime? @map("notifications_read_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  senderNames      SenderName[]
  contacts         Contact[]
  contactGroups    ContactGroup[]
  tags             Tag[]
  messages         Message[]
  transactions     Transaction[]
  apiKeys          ApiKey[]
  messageTemplates MessageTemplate[]
  otpRequests         OtpRequest[]
  campaigns           Campaign[]
  scheduledSms        ScheduledSms[]
  creditTransactions  CreditTransaction[]
  apiLogs             ApiLog[]

  @@map("users")
}

enum MessageType {
  SMS
  OTP
}

enum Channel {
  WEB
  API
}

model Message {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id])
  campaignId  String?     @map("campaign_id")
  campaign    Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  type        MessageType @default(SMS)
  channel     Channel     @default(WEB)
  senderName  String      @map("sender_name")
  recipient   String
  content     String
  status      String      @default("pending")
  creditCost  Int         @default(1) @map("credit_cost")
  sentAt      DateTime?   @map("sent_at")
  deliveredAt DateTime?   @map("delivered_at")
  gatewayId   String?     @map("gateway_id")
  errorCode   String?     @map("error_code")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([status])
  @@index([campaignId])
  @@index([type])
  @@map("messages")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  name      String
  key       String    @unique
  isActive  Boolean   @default(true) @map("is_active")
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([key])
  @@map("api_keys")
}

model Contact {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  name      String
  phone     String
  email     String?
  tags      String?
  createdAt DateTime @default(now()) @map("created_at")

  groups    ContactGroupMember[]
  contactTags ContactTag[]

  @@unique([userId, phone])
  @@index([userId])
  @@map("contacts")
}

model Tag {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id])
  name      String
  color     String      @default("#94A3B8")
  createdAt DateTime    @default(now()) @map("created_at")

  contactTags ContactTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model ContactTag {
  id        String   @id @default(cuid())
  contactId String   @map("contact_id")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String   @map("tag_id")
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

model ContactGroup {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  members   ContactGroupMember[]
  campaigns Campaign[]

  @@index([userId])
  @@map("contact_groups")
}

model ContactGroupMember {
  id        String       @id @default(cuid())
  groupId   String       @map("group_id")
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contactId String       @map("contact_id")
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
  @@map("contact_group_members")
}

model SenderName {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id])
  name       String
  status     String    @default("pending")
  rejectNote String?   @map("reject_note")
  approvedAt DateTime? @map("approved_at")
  approvedBy String?   @map("approved_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([userId, name])
  @@index([status])
  @@map("sender_names")
}

model Package {
  id            String   @id @default(cuid())
  name          String
  price         Int
  bonusPercent  Int      @default(0) @map("bonus_percent")
  totalCredits  Int      @map("total_credits")
  maxSenders    Int      @default(5) @map("max_senders")
  durationDays  Int      @map("duration_days")
  isActive      Boolean  @default(true) @map("is_active")
  isBestSeller  Boolean  @default(false) @map("is_best_seller")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("packages")
}

model MessageTemplate {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  name      String
  content   String
  category  String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaigns Campaign[]

  @@index([userId])
  @@map("message_templates")
}

model OtpRequest {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")           // nullable for pre-registration OTP
  user      User?    @relation(fields: [userId], references: [id])
  refCode   String   @unique @map("ref_code")
  phone     String
  code      String   // hashed OTP
  purpose   String   @default("verify") // verify, login, transaction, register
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, phone, createdAt])
  @@index([phone, createdAt])
  @@map("otp_requests")
}

model Campaign {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  user            User             @relation(fields: [userId], references: [id])
  name            String
  contactGroupId  String?          @map("contact_group_id")
  contactGroup    ContactGroup?    @relation(fields: [contactGroupId], references: [id], onDelete: SetNull)
  templateId      String?          @map("template_id")
  template        MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  senderName      String?          @map("sender_name")
  status          String           @default("draft")
  scheduledAt     DateTime?        @map("scheduled_at")
  totalRecipients Int              @default(0) @map("total_recipients")
  sentCount       Int              @default(0) @map("sent_count")
  deliveredCount  Int              @default(0) @map("delivered_count")
  failedCount     Int              @default(0) @map("failed_count")
  creditReserved  Int              @default(0) @map("credit_reserved")
  creditUsed      Int              @default(0) @map("credit_used")
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  messages        Message[]

  @@index([userId, status])
  @@index([scheduledAt])
  @@map("campaigns")
}

model ScheduledSms {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  senderName  String    @map("sender_name")
  recipient   String
  content     String
  scheduledAt DateTime  @map("scheduled_at")
  status      String    @default("pending") // pending, sent, failed, cancelled
  messageId   String?   @map("message_id")
  errorCode   String?   @map("error_code")
  creditCost  Int       @default(1) @map("credit_cost")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("scheduled_sms")
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  amount      Int      // positive = credit added, negative = deducted
  balance     Int      // credits remaining after this transaction
  type        String   // TOPUP | SMS_SEND | REFUND | BONUS | ADJUSTMENT
  description String
  refId       String?  @map("ref_id") // transactionId or messageId
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([type])
  @@map("credit_transactions")
}

model ApiLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  method     String   // GET, POST, DELETE
  url        String   // /api/v1/sms/send
  reqHeaders String?  @map("req_headers")  // JSON — masked
  reqBody    String?  @map("req_body")     // JSON — masked
  resStatus  Int      @map("res_status")   // 200, 400, 500
  resBody    String?  @map("res_body")     // JSON
  latencyMs  Int      @map("latency_ms")   // response time
  errorCode  String?  @map("error_code")   // VALIDATION_ERROR, INTERNAL_ERROR
  errorMsg   String?  @map("error_msg")    // generic error message
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([resStatus])
  @@index([url])
  @@map("api_logs")
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  packageId   String?   @map("package_id")
  amount      Int
  credits     Int
  method      String
  status      String    @default("pending")
  slipUrl     String?   @map("slip_url")
  reference   String?
  verifiedAt  DateTime? @map("verified_at")
  verifiedBy  String?   @map("verified_by")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([status])
  @@map("transactions")
}
