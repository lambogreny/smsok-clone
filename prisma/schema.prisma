generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  plan              String            @default("free")
  sendingHoursStart Int               @default(8) @map("sending_hours_start")
  sendingHoursEnd   Int               @default(20) @map("sending_hours_end")
  require2fa        Boolean           @default(false) @map("require_2fa")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  campaigns         Campaign[]
  consents          Consent[]
  contactGroups     ContactGroup[]
  contacts          Contact[]
  customFields      CustomField[]
  customerTaxInfos  CustomerTaxInfo[]
  dataRequests      DataRequest[]
  invoices          Invoice[]
  memberships       Membership[]
  messageTemplates  MessageTemplate[]
  messages          Message[]
  optOutLogs        OptOutLog[]
  orders            Order[]
  billingInfo       OrgBillingInfo?
  invites           OrgInvite[]
  packagePurchases  PackagePurchase[]
  payments          Payment[]
  quotations        Quotation[]
  roles             Role[]
  scheduledSms      ScheduledSms[]
  senderNames       SenderName[]
  shortLinks        ShortLink[]
  subscriptions     Subscription[]
  tags              Tag[]
  taxDocuments      TaxDocument[]
  taxProfiles       TaxProfile[]
  transactions      Transaction[]
  userRoles         UserRole[]
  webhooks          Webhook[]
  whtCertificates   WhtCertificate[]

  @@map("organizations")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  organizationId String       @map("organization_id")
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model OrgInvite {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  email          String
  role           OrgRole      @default(MEMBER)
  token          String       @unique
  expiresAt      DateTime     @map("expires_at")
  acceptedAt     DateTime?    @map("accepted_at")
  invitedBy      String       @map("invited_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@map("org_invites")
}

model Role {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  key            String?
  name           String
  description    String?
  isSystemRole   Boolean          @default(false) @map("is_system_role")
  parentRoleId   String?          @map("parent_role_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  admin_roles    admin_roles[]
  permissions    RolePermission[]
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentRole     Role?            @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles     Role[]           @relation("RoleHierarchy")
  userRoles      UserRole[]

  @@unique([organizationId, key])
  @@unique([organizationId, name])
  @@index([organizationId, name])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  key         String?          @unique
  action      String
  resource    String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@unique([action, resource])
  @@index([action, resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId         String       @map("user_id")
  roleId         String       @map("role_id")
  organizationId String       @map("organization_id")
  assignedAt     DateTime     @default(now()) @map("assigned_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId, organizationId])
  @@index([organizationId])
  @@index([userId, organizationId])
  @@map("user_roles")
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  phone               String             @unique
  name                String
  password            String
  role                String             @default("user")
  emailVerified       Boolean            @default(false)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  mustChangePassword  Boolean            @default(false) @map("must_change_password")
  phoneVerified       Boolean            @default(false) @map("phone_verified")
  notificationsReadAt DateTime?          @map("notifications_read_at")
  acceptedTermsAt     DateTime?          @map("accepted_terms_at")
  failedLoginAttempts Int                @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?          @map("locked_until")
  securityVersion     Int                @default(1) @map("security_version")
  deletedAt           DateTime?          @map("deleted_at")
  apiKeys             ApiKey[]
  apiLogs             ApiLog[]
  auditLogs           AuditLog[]
  autoTopupSetting    AutoTopupSetting?
  bankAccounts        BankAccount[]
  billingInfo         BillingInfo?
  campaigns           Campaign[]
  consentStatuses     ConsentStatus[]
  contactGroups       ContactGroup[]
  contacts            Contact[]
  couponUsages        CouponUsage[]
  customFields        CustomField[]
  customerTaxInfo     CustomerTaxInfo?
  invoices            Invoice[]
  memberships         Membership[]
  messageTemplates    MessageTemplate[]
  messages            Message[]
  notificationPrefs   NotificationPrefs?
  orders              Order[]
  otpRequests         OtpRequest[]
  packagePurchases    PackagePurchase[]
  passwordHistory     PasswordHistory[]
  payments            Payment[]
  consentLogs         PdpaConsentLog[]
  createdPolicies     PdpaPolicy[]       @relation("PolicyCreator")
  quotations          Quotation[]
  scheduledSms        ScheduledSms[]
  senderNames         SenderName[]
  shortLinks          ShortLink[]
  subscriptions       Subscription[]
  tags                Tag[]
  taxDocuments        TaxDocument[]
  taxProfiles         TaxProfile[]
  termsAcceptances    TermsAcceptance[]
  transactions        Transaction[]
  twoFactorAuth       TwoFactorAuth?
  onboarding          UserOnboarding?
  userRoles           UserRole[]
  sessions            UserSession[]
  webhooks            Webhook[]
  whtCertificates     WhtCertificate[]
  workspaceSettings   WorkspaceSettings?

  @@map("users")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  tokenHash    String   @unique @map("token_hash")
  deviceName   String?  @map("device_name")
  deviceType   String?  @map("device_type")
  browser      String?
  os           String?
  ipAddress    String?  @map("ip_address")
  location     String?
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastActiveAt])
  @@index([tokenHash])
  @@map("user_sessions")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_history")
}

model Message {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  senderName     String        @map("sender_name")
  recipient      String
  content        String
  status         String        @default("pending")
  creditCost     Int           @default(1) @map("credit_cost")
  sentAt         DateTime?     @map("sent_at")
  deliveredAt    DateTime?     @map("delivered_at")
  errorCode      String?       @map("error_code")
  createdAt      DateTime      @default(now()) @map("created_at")
  gatewayId      String?       @map("gateway_id")
  campaignId     String?       @map("campaign_id")
  channel        Channel       @default(WEB)
  type           MessageType   @default(SMS)
  campaign       Campaign?     @relation(fields: [campaignId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([status])
  @@index([campaignId])
  @@index([type])
  @@map("messages")
}

model ApiKey {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  name           String
  key            String        @unique
  keyPrefix      String        @default("") @map("key_prefix")
  permissions    String[]      @default([])
  isActive       Boolean       @default(true) @map("is_active")
  lastUsed       DateTime?     @map("last_used")
  createdAt      DateTime      @default(now()) @map("created_at")
  ipWhitelist    String[]      @default([]) @map("ip_whitelist")
  rateLimit      Int           @default(60) @map("rate_limit")
  revokedAt      DateTime?     @map("revoked_at")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  apiLogs        ApiLog[]

  @@index([key])
  @@index([organizationId])
  @@map("api_keys")
}

model Contact {
  id                String               @id @default(cuid())
  userId            String               @map("user_id")
  organizationId    String?              @map("organization_id")
  name              String
  phone             String
  email             String?
  /// Deprecated legacy comma-separated tags. New writes must use Tag + ContactTag.
  tags              String?
  smsConsent        Boolean              @default(true) @map("sms_consent")
  consentStatus     String               @default("OPTED_IN") @map("consent_status")
  consentAt         DateTime?            @map("consent_at")
  optOutAt          DateTime?            @map("opt_out_at")
  optOutReason      String?              @map("opt_out_reason")
  createdAt         DateTime             @default(now()) @map("created_at")
  consents          Consent[]
  groups            ContactGroupMember[]
  contactTags       ContactTag[]
  organization      Organization?        @relation(fields: [organizationId], references: [id])
  user              User                 @relation(fields: [userId], references: [id])
  customFieldValues CustomFieldValue[]
  dataRequests      DataRequest[]
  optOutLogs        OptOutLog[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([organizationId])
  @@map("contacts")
}

model CustomField {
  id             String             @id @default(cuid())
  userId         String             @map("user_id")
  organizationId String?            @map("organization_id")
  name           String
  key            String?
  type           String             @default("text")
  options        String?
  required       Boolean            @default(false)
  position       Int                @default(0)
  createdAt      DateTime           @default(now()) @map("created_at")
  values         CustomFieldValue[]
  organization   Organization?      @relation(fields: [organizationId], references: [id])
  user           User               @relation(fields: [userId], references: [id])

  @@unique([userId, name])
  @@index([userId])
  @@index([organizationId])
  @@map("custom_fields")
}

model CustomFieldValue {
  id        String      @id @default(cuid())
  contactId String      @map("contact_id")
  fieldId   String      @map("field_id")
  value     String
  createdAt DateTime    @default(now()) @map("created_at")
  contact   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, fieldId])
  @@index([fieldId])
  @@map("custom_field_values")
}

model Tag {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  name           String
  color          String        @default("#94A3B8")
  createdAt      DateTime      @default(now()) @map("created_at")
  contactTags    ContactTag[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@unique([userId, name])
  @@index([userId])
  @@index([organizationId])
  @@map("tags")
}

model ContactTag {
  id        String  @id @default(cuid())
  contactId String  @map("contact_id")
  tagId     String  @map("tag_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

model ContactGroup {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  organizationId String?              @map("organization_id")
  name           String
  createdAt      DateTime             @default(now()) @map("created_at")
  campaigns      Campaign[]
  members        ContactGroupMember[]
  organization   Organization?        @relation(fields: [organizationId], references: [id])
  user           User                 @relation(fields: [userId], references: [id])

  @@unique([userId, name])
  @@index([userId, createdAt])
  @@index([organizationId])
  @@map("contact_groups")
}

model ContactGroupMember {
  id        String       @id @default(cuid())
  groupId   String       @map("group_id")
  contactId String       @map("contact_id")
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
  @@map("contact_group_members")
}

model SenderName {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  organizationId String?              @map("organization_id")
  name           String
  status         String               @default("DRAFT")
  accountType    String?              @map("account_type")
  rejectNote     String?              @map("reject_note")
  adminNotes     String?              @map("admin_notes")
  submittedAt    DateTime?            @map("submitted_at")
  approvedAt     DateTime?            @map("approved_at")
  approvedBy     String?              @map("approved_by")
  expiresAt      DateTime?            @map("expires_at")
  operatorSentAt DateTime?            @map("operator_sent_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @default(now()) @updatedAt @map("updated_at")
  senderType     String?              @map("sender_type")
  documents      SenderNameDocument[]
  history        SenderNameHistory[]
  urls           SenderNameUrl[]
  organization   Organization?        @relation(fields: [organizationId], references: [id])
  user           User                 @relation(fields: [userId], references: [id])

  @@unique([userId, name])
  @@index([userId, status])
  @@index([status])
  @@index([organizationId])
  @@map("sender_names")
}

model SenderNameDocument {
  id           String     @id @default(cuid())
  senderNameId String     @map("sender_name_id")
  type         String
  fileName     String     @map("file_name")
  fileUrl      String     @map("file_url")
  fileSize     Int        @map("file_size")
  mimeType     String     @map("mime_type")
  verified     Boolean    @default(false)
  verifiedBy   String?    @map("verified_by")
  verifiedAt   DateTime?  @map("verified_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  senderName   SenderName @relation(fields: [senderNameId], references: [id], onDelete: Cascade)

  @@index([senderNameId])
  @@map("sender_name_documents")
}

model SenderNameUrl {
  id           String     @id @default(cuid())
  senderNameId String     @map("sender_name_id")
  domain       String
  createdAt    DateTime   @default(now()) @map("created_at")
  senderName   SenderName @relation(fields: [senderNameId], references: [id], onDelete: Cascade)

  @@index([senderNameId])
  @@map("sender_name_urls")
}

model SenderNameHistory {
  id           String     @id @default(cuid())
  senderNameId String     @map("sender_name_id")
  action       String
  fromStatus   String?    @map("from_status")
  toStatus     String     @map("to_status")
  note         String?
  performedBy  String?    @map("performed_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  senderName   SenderName @relation(fields: [senderNameId], references: [id], onDelete: Cascade)

  @@index([senderNameId, createdAt])
  @@map("sender_name_history")
}

model MessageTemplate {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  name           String
  content        String
  category       String        @default("general")
  variables      String[]      @default([])
  segmentCount   Int           @default(1) @map("segment_count")
  isPublic       Boolean       @default(false) @map("is_public")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  campaigns      Campaign[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId, name])
  @@index([userId, deletedAt, updatedAt])
  @@index([organizationId])
  @@index([isPublic])
  @@map("message_templates")
}

model OtpRequest {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id")
  phone      String
  code       String
  purpose    String    @default("verify")
  attempts   Int       @default(0)
  verified   Boolean   @default(false)
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  refCode    String    @unique @map("ref_code")
  verifiedAt DateTime? @map("verified_at")
  user       User?     @relation(fields: [userId], references: [id])

  @@index([userId, phone, createdAt])
  @@index([phone, createdAt])
  @@map("otp_requests")
}

model Campaign {
  id               String            @id @default(cuid())
  userId           String            @map("user_id")
  organizationId   String?           @map("organization_id")
  name             String
  contactGroupId   String?           @map("contact_group_id")
  templateId       String?           @map("template_id")
  senderName       String?           @map("sender_name")
  messageBody      String?           @map("message_body")
  segmentCount     Int               @default(1) @map("segment_count")
  status           String            @default("DRAFT")
  priority         String            @default("LOW")
  recipientSource  String?           @map("recipient_source")
  scheduledAt      DateTime?         @map("scheduled_at")
  totalRecipients  Int               @default(0) @map("total_recipients")
  validRecipients  Int               @default(0) @map("valid_recipients")
  sentCount        Int               @default(0) @map("sent_count")
  deliveredCount   Int               @default(0) @map("delivered_count")
  failedCount      Int               @default(0) @map("failed_count")
  creditReserved   Int               @default(0) @map("credit_reserved")
  creditUsed       Int               @default(0) @map("credit_used")
  estimatedCost    Decimal?          @map("estimated_cost") @db.Decimal(10, 2)
  actualCost       Decimal?          @map("actual_cost") @db.Decimal(10, 2)
  startedAt        DateTime?         @map("started_at")
  completedAt      DateTime?         @map("completed_at")
  cancelledAt      DateTime?         @map("cancelled_at")
  cancelledBy      String?           @map("cancelled_by")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  campaignMessages CampaignMessage[]
  contactGroup     ContactGroup?     @relation(fields: [contactGroupId], references: [id])
  organization     Organization?     @relation(fields: [organizationId], references: [id])
  template         MessageTemplate?  @relation(fields: [templateId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  messages         Message[]
  shortLinks       ShortLink[]

  @@index([userId, status])
  @@index([organizationId, status])
  @@index([scheduledAt])
  @@index([status])
  @@map("campaigns")
}

model CampaignMessage {
  id                String                @id @default(cuid())
  campaignId        String                @map("campaign_id")
  phoneNumber       String                @map("phone_number") @db.VarChar(15)
  status            CampaignMessageStatus @default(PENDING)
  providerMessageId String?               @map("provider_message_id")
  errorCode         String?               @map("error_code") @db.VarChar(20)
  errorMessage      String?               @map("error_message")
  sentAt            DateTime?             @map("sent_at")
  deliveredAt       DateTime?             @map("delivered_at")
  cost              Decimal?              @db.Decimal(6, 4)
  retryCount        Int                   @default(0) @map("retry_count")
  createdAt         DateTime              @default(now()) @map("created_at")
  campaign          Campaign              @relation(fields: [campaignId], references: [id])

  @@index([campaignId, status])
  @@index([phoneNumber])
  @@index([status])
  @@map("campaign_messages")
}

model ScheduledSms {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  senderName     String        @map("sender_name")
  recipient      String
  content        String
  scheduledAt    DateTime      @map("scheduled_at")
  status         String        @default("pending")
  messageId      String?       @map("message_id")
  errorCode      String?       @map("error_code")
  creditCost     Int           @default(1) @map("credit_cost")
  deductions     Json?         @map("deductions")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId, scheduledAt])
  @@index([organizationId])
  @@index([status, scheduledAt])
  @@map("scheduled_sms")
}

model AutoTopupSetting {
  id                 String      @id @default(cuid())
  userId             String      @unique @map("user_id")
  isEnabled          Boolean     @default(false) @map("is_enabled")
  tierId             String      @map("tier_id")
  threshold          Int         @default(100)
  maxPerMonth        Int         @default(3) @map("max_per_month")
  purchasedThisMonth Int         @default(0) @map("purchased_this_month")
  monthResetAt       DateTime    @default(now()) @map("month_reset_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  tier               PackageTier @relation(fields: [tierId], references: [id])
  user               User        @relation(fields: [userId], references: [id])

  @@map("auto_topup_settings")
}

model PackageTier {
  id                String             @id @default(cuid())
  name              String
  tierCode          String             @unique @map("tier_code")
  price             Decimal            @db.Decimal(10, 2)
  smsQuota          Int                @map("sms_quota")
  bonusPercent      Int                @default(0) @map("bonus_percent")
  totalSms          Int                @map("total_sms")
  senderNameLimit   Int?               @map("sender_name_limit")
  expiryMonths      Int                @map("expiry_months")
  isActive          Boolean            @default(true) @map("is_active")
  isTrial           Boolean            @default(false) @map("is_trial")
  sortOrder         Int                @default(0) @map("sort_order")
  createdAt         DateTime           @default(now()) @map("created_at")
  autoTopupSettings AutoTopupSetting[]
  orders            Order[]
  purchases         PackagePurchase[]
  payments          Payment[]

  @@map("package_tiers")
}

model PackagePurchase {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  tierId         String        @map("tier_id")
  smsTotal       Int           @map("sms_total")
  smsUsed        Int           @default(0) @map("sms_used")
  purchasedAt    DateTime      @default(now()) @map("purchased_at")
  expiresAt      DateTime      @map("expires_at")
  isActive       Boolean       @default(true) @map("is_active")
