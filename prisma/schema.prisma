generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════
// Organization & Multi-Tenant
// ══════════════════════════════════════════════════════════

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  plan           String   @default("free") // free, starter, business, enterprise
  sendingHoursStart Int   @default(8)  @map("sending_hours_start")  // PDPA: ห้ามส่ง marketing นอกเวลา
  sendingHoursEnd   Int   @default(20) @map("sending_hours_end")
  require2fa     Boolean  @default(false) @map("require_2fa")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  memberships        Membership[]
  invites            OrgInvite[]
  messages           Message[]
  contacts           Contact[]
  apiKeys            ApiKey[]
  campaigns          Campaign[]
  tags               Tag[]
  contactGroups      ContactGroup[]
  senderNames        SenderName[]
  messageTemplates   MessageTemplate[]
  scheduledSms       ScheduledSms[]
  invoices           Invoice[]
  transactions       Transaction[]
  taxDocuments       TaxDocument[]
  whtCertificates    WhtCertificate[]
  taxProfiles        TaxProfile[]
  webhooks           Webhook[]
  customFields       CustomField[]
  consents           Consent[]
  optOutLogs         OptOutLog[]
  dataRequests       DataRequest[]
  auditLogs          AuditLog[]
  billingInfo        OrgBillingInfo?
  payments           Payment[]
  subscriptions      Subscription[]
  customerTaxInfos   CustomerTaxInfo[]
  packagePurchases   PackagePurchase[]
  roles              Role[]
  userRoles          UserRole[]
  quotations         Quotation[]
  shortLinks         ShortLink[]
  orders             Order[]

  @@map("organizations")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  organizationId String       @map("organization_id")
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now()) @map("created_at")
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model OrgInvite {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  email          String
  role           OrgRole      @default(MEMBER)
  token          String       @unique
  expiresAt      DateTime     @map("expires_at")
  acceptedAt     DateTime?    @map("accepted_at")
  invitedBy      String       @map("invited_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@map("org_invites")
}

// ══════════════════════════════════════════════════════════
// Dynamic RBAC — Roles & Permissions
// ══════════════════════════════════════════════════════════

model Role {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  name           String           // "Owner", "Admin", "Marketing_Lead", etc.
  description    String?
  isSystemRole   Boolean          @default(false) @map("is_system_role")
  parentRoleId   String?          @map("parent_role_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentRole     Role?            @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles     Role[]           @relation("RoleHierarchy")
  permissions    RolePermission[]
  userRoles      UserRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  action      String           // "create", "read", "update", "delete", "manage"
  resource    String           // "sms", "contact", "campaign", etc.
  description String?
  roles       RolePermission[]

  @@unique([action, resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId         String       @map("user_id")
  roleId         String       @map("role_id")
  organizationId String       @map("organization_id")
  assignedAt     DateTime     @default(now()) @map("assigned_at")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, roleId, organizationId])
  @@index([organizationId])
  @@index([userId, organizationId])
  @@map("user_roles")
}

// ══════════════════════════════════════════════════════════
// User (updated with memberships relation)
// ══════════════════════════════════════════════════════════

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  phone               String              @default("")
  name                String
  password            String
  role                String              @default("user")
  emailVerified       Boolean             @default(false)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  mustChangePassword  Boolean             @default(false) @map("must_change_password")
  phoneVerified       Boolean             @default(false) @map("phone_verified")
  notificationsReadAt DateTime?           @map("notifications_read_at")
  acceptedTermsAt     DateTime?           @map("accepted_terms_at")
  failedLoginAttempts Int                 @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?           @map("locked_until")
  securityVersion     Int                 @default(1) @map("security_version")
  deletedAt           DateTime?           @map("deleted_at")
  passwordHistory     PasswordHistory[]
  memberships         Membership[]
  apiKeys             ApiKey[]
  apiLogs             ApiLog[]
  billingInfo         BillingInfo?
  campaigns           Campaign[]
  contactGroups       ContactGroup[]
  contacts            Contact[]
  customFields        CustomField[]
  invoices            Invoice[]
  messageTemplates    MessageTemplate[]
  messages            Message[]
  otpRequests         OtpRequest[]
  scheduledSms        ScheduledSms[]
  senderNames         SenderName[]
  tags                Tag[]
  taxDocuments        TaxDocument[]
  termsAcceptances    TermsAcceptance[]
  transactions        Transaction[]
  twoFactorAuth       TwoFactorAuth?
  webhooks            Webhook[]
  whtCertificates     WhtCertificate[]
  workspaceSettings   WorkspaceSettings?
  notificationPrefs   NotificationPrefs?
  auditLogs           AuditLog[]
  payments            Payment[]
  subscriptions       Subscription[]
  onboarding          UserOnboarding?
  customerTaxInfo     CustomerTaxInfo?
  packagePurchases    PackagePurchase[]
  couponUsages        CouponUsage[]
  userRoles           UserRole[]
  quotations          Quotation[]
  shortLinks          ShortLink[]
  consentLogs         PdpaConsentLog[]
  createdPolicies     PdpaPolicy[]     @relation("PolicyCreator")
  autoTopupSetting    AutoTopupSetting?
  bankAccounts        BankAccount[]
  sessions            UserSession[]
  taxProfiles         TaxProfile[]
  orders              Order[]

  @@map("users")
}

model UserSession {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  tokenHash     String    @unique @map("token_hash") // SHA-256 hash of JWT token
  deviceName    String?   @map("device_name")
  deviceType    String?   @map("device_type") // desktop, mobile, tablet
  browser       String?
  os            String?
  ipAddress     String?   @map("ip_address")
  location      String?
  lastActiveAt  DateTime  @default(now()) @map("last_active_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastActiveAt])
  @@index([tokenHash])
  @@map("user_sessions")
}

model PasswordHistory {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  passwordHash  String   @map("password_hash")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_history")
}

// ══════════════════════════════════════════════════════════
// Core Business Models (with organizationId FK)
// ══════════════════════════════════════════════════════════

model Message {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  senderName     String        @map("sender_name")
  recipient      String
  content        String
  status         String        @default("pending")
  creditCost     Int           @default(1) @map("credit_cost")
  sentAt         DateTime?     @map("sent_at")
  deliveredAt    DateTime?     @map("delivered_at")
  errorCode      String?       @map("error_code")
  createdAt      DateTime      @default(now()) @map("created_at")
  gatewayId      String?       @map("gateway_id")
  campaignId     String?       @map("campaign_id")
  channel        Channel       @default(WEB)
  type           MessageType   @default(SMS)
  campaign       Campaign?     @relation(fields: [campaignId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([status])
  @@index([campaignId])
  @@index([type])
  @@map("messages")
}

model ApiKey {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  name           String
  key            String        @unique
  keyPrefix      String        @default("") @map("key_prefix")
  permissions    String[]      @default([]) // e.g., ["sms:send", "contacts:read", "campaigns:write"]
  isActive       Boolean       @default(true) @map("is_active")
  lastUsed       DateTime?     @map("last_used")
  createdAt      DateTime      @default(now()) @map("created_at")
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  apiLogs        ApiLog[]

  @@index([key])
  @@index([organizationId])
  @@map("api_keys")
}

model Contact {
  id                String               @id @default(cuid())
  userId            String               @map("user_id")
  organizationId    String?              @map("organization_id")
  name              String
  phone             String
  email             String?
  tags              String?
  smsConsent        Boolean              @default(true) @map("sms_consent")
  consentStatus     String               @default("OPTED_IN") @map("consent_status")
  consentAt         DateTime?            @map("consent_at")
  optOutAt          DateTime?            @map("opt_out_at")
  optOutReason      String?              @map("opt_out_reason")
  createdAt         DateTime             @default(now()) @map("created_at")
  groups            ContactGroupMember[]
  contactTags       ContactTag[]
  customFieldValues CustomFieldValue[]
  consents          Consent[]
  optOutLogs        OptOutLog[]
  dataRequests      DataRequest[]
  user              User                 @relation(fields: [userId], references: [id])
  organization      Organization?        @relation(fields: [organizationId], references: [id])

  @@unique([userId, phone])
  @@index([userId])
  @@index([organizationId])
  @@map("contacts")
}

model CustomField {
  id             String             @id @default(cuid())
  userId         String             @map("user_id")
  organizationId String?            @map("organization_id")
  name           String
  key            String?
  type           String             @default("text")
  options        String?
  required       Boolean            @default(false)
  position       Int                @default(0)
  createdAt      DateTime           @default(now()) @map("created_at")
  values         CustomFieldValue[]
  user           User               @relation(fields: [userId], references: [id])
  organization   Organization?      @relation(fields: [organizationId], references: [id])

  @@unique([userId, name])
  @@index([userId])
  @@index([organizationId])
  @@map("custom_fields")
}

model CustomFieldValue {
  id        String      @id @default(cuid())
  contactId String      @map("contact_id")
  fieldId   String      @map("field_id")
  value     String
  createdAt DateTime    @default(now()) @map("created_at")
  contact   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, fieldId])
  @@index([fieldId])
  @@map("custom_field_values")
}

model Tag {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  name           String
  color          String        @default("#94A3B8")
  createdAt      DateTime      @default(now()) @map("created_at")
  contactTags    ContactTag[]
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([userId, name])
  @@index([userId])
  @@index([organizationId])
  @@map("tags")
}

model ContactTag {
  id        String  @id @default(cuid())
  contactId String  @map("contact_id")
  tagId     String  @map("tag_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

model ContactGroup {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  organizationId String?              @map("organization_id")
  name           String
  createdAt      DateTime             @default(now()) @map("created_at")
  campaigns      Campaign[]
  members        ContactGroupMember[]
  user           User                 @relation(fields: [userId], references: [id])
  organization   Organization?        @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@map("contact_groups")
}

model ContactGroupMember {
  id        String       @id @default(cuid())
  groupId   String       @map("group_id")
  contactId String       @map("contact_id")
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
  @@map("contact_group_members")
}

model SenderName {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  name           String
  status         String        @default("DRAFT") // DRAFT→PENDING→REVIEWING→SUBMITTED_TO_OPERATOR→APPROVED/REJECTED/EXPIRED
  accountType    String?       @map("account_type") // "corporate" | "individual"
  rejectNote     String?       @map("reject_note")
  adminNotes     String?       @map("admin_notes") @db.Text
  submittedAt    DateTime?     @map("submitted_at")
  approvedAt     DateTime?     @map("approved_at")
  approvedBy     String?       @map("approved_by")
  expiresAt      DateTime?     @map("expires_at") // 1 year from approval
  operatorSentAt DateTime?     @map("operator_sent_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documents      SenderNameDocument[]
  urls           SenderNameUrl[]
  history        SenderNameHistory[]

  @@unique([userId, name])
  @@index([status])
  @@index([organizationId])
  @@map("sender_names")
}

model SenderNameDocument {
  id           String     @id @default(cuid())
  senderNameId String     @map("sender_name_id")
  type         String     // "company_cert", "vat_cert", "id_card", "loa", "selfie", "brand_proof"
  fileName     String     @map("file_name")
  fileUrl      String     @map("file_url")
  fileSize     Int        @map("file_size")
  mimeType     String     @map("mime_type")
  verified     Boolean    @default(false)
  verifiedBy   String?    @map("verified_by")
  verifiedAt   DateTime?  @map("verified_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  senderName   SenderName @relation(fields: [senderNameId], references: [id], onDelete: Cascade)

  @@index([senderNameId])
  @@map("sender_name_documents")
}

model SenderNameUrl {
  id           String     @id @default(cuid())
  senderNameId String     @map("sender_name_id")
  domain       String
  createdAt    DateTime   @default(now()) @map("created_at")
  senderName   SenderName @relation(fields: [senderNameId], references: [id], onDelete: Cascade)

  @@index([senderNameId])
  @@map("sender_name_urls")
}

model SenderNameHistory {
  id           String     @id @default(cuid())
  senderNameId String     @map("sender_name_id")
  action       String     // "submitted", "reviewing", "approved", "rejected", "expired", "operator_sent"
  fromStatus   String?    @map("from_status")
  toStatus     String     @map("to_status")
  note         String?    @db.Text
  performedBy  String?    @map("performed_by") // admin id or "system"
  createdAt    DateTime   @default(now()) @map("created_at")
  senderName   SenderName @relation(fields: [senderNameId], references: [id], onDelete: Cascade)

  @@index([senderNameId, createdAt])
  @@map("sender_name_history")
}

// Package model removed — replaced by PackageTier

model MessageTemplate {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  name           String
  content        String        @db.Text
  category       String        @default("GENERAL")  // OTP, TRANSACTIONAL, MARKETING, NOTIFICATION, GENERAL
  variables      String[]      @default([])          // extracted {{varName}} list
  segmentCount   Int           @default(1) @map("segment_count")
  isPublic       Boolean       @default(false) @map("is_public")  // library/pre-built templates
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  campaigns      Campaign[]
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId, deletedAt])
  @@index([organizationId])
  @@index([isPublic])
  @@map("message_templates")
}

model OtpRequest {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  phone     String
  code      String
  purpose   String   @default("verify")
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  refCode   String   @unique @map("ref_code")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, phone, createdAt])
  @@index([phone, createdAt])
  @@map("otp_requests")
}

model Campaign {
  id              String            @id @default(cuid())
  userId          String            @map("user_id")
  organizationId  String?           @map("organization_id")
  name            String            @db.VarChar(100)
  contactGroupId  String?           @map("contact_group_id")
  templateId      String?           @map("template_id")
  senderName      String?           @map("sender_name")
  messageBody     String?           @map("message_body") @db.Text
  segmentCount    Int               @default(1) @map("segment_count")
  status          String            @default("DRAFT") // CampaignStatus: DRAFT, SCHEDULED, QUEUING, SENDING, PAUSED, COMPLETED, CANCELLED
  priority        String            @default("LOW")   // CampaignPriority: HIGH, MEDIUM, LOW
  recipientSource String?           @map("recipient_source") // RecipientSource: GROUP, CSV, MANUAL
  scheduledAt     DateTime?         @map("scheduled_at")
  totalRecipients Int               @default(0) @map("total_recipients")
  validRecipients Int               @default(0) @map("valid_recipients")
  sentCount       Int               @default(0) @map("sent_count")
  deliveredCount  Int               @default(0) @map("delivered_count")
  failedCount     Int               @default(0) @map("failed_count")
  creditReserved  Int               @default(0) @map("credit_reserved")
  creditUsed      Int               @default(0) @map("credit_used")
  estimatedCost   Decimal?          @map("estimated_cost") @db.Decimal(10, 2)
  actualCost      Decimal?          @map("actual_cost") @db.Decimal(10, 2)
  startedAt       DateTime?         @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  cancelledAt     DateTime?         @map("cancelled_at")
  cancelledBy     String?           @map("cancelled_by")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  contactGroup    ContactGroup?     @relation(fields: [contactGroupId], references: [id])
  template        MessageTemplate?  @relation(fields: [templateId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
  organization    Organization?     @relation(fields: [organizationId], references: [id])
  messages        Message[]
  shortLinks      ShortLink[]
  campaignMessages CampaignMessage[]

  @@index([userId, status])
  @@index([organizationId, status])
  @@index([scheduledAt])
  @@index([status])
  @@map("campaigns")
}

model CampaignMessage {
  id                String                @id @default(cuid())
  campaignId        String                @map("campaign_id")
  phoneNumber       String                @map("phone_number") @db.VarChar(15)
  status            CampaignMessageStatus @default(PENDING)
  providerMessageId String?               @map("provider_message_id")
  errorCode         String?               @map("error_code") @db.VarChar(20)
  errorMessage      String?               @map("error_message")
  sentAt            DateTime?             @map("sent_at")
  deliveredAt       DateTime?             @map("delivered_at")
  cost              Decimal?              @db.Decimal(6, 4)
  retryCount        Int                   @default(0) @map("retry_count")
  createdAt         DateTime              @default(now()) @map("created_at")
  campaign          Campaign              @relation(fields: [campaignId], references: [id])

  @@index([campaignId, status])
  @@index([phoneNumber])
  @@index([status])
  @@map("campaign_messages")
}

model ScheduledSms {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  senderName     String        @map("sender_name")
  recipient      String
  content        String
  scheduledAt    DateTime      @map("scheduled_at")
  status         String        @default("pending")
  messageId      String?       @map("message_id")
  errorCode      String?       @map("error_code")
  creditCost     Int           @default(1) @map("credit_cost")
  createdAt      DateTime      @default(now()) @map("created_at")
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId, scheduledAt])
  @@index([organizationId])
  @@index([status, scheduledAt])
  @@map("scheduled_sms")
}

// ══════════════════════════════════════════════════════════
// Auto Top-up Settings (per user)
// ══════════════════════════════════════════════════════════

model AutoTopupSetting {
  id             String      @id @default(cuid())
  userId         String      @unique @map("user_id")
  isEnabled      Boolean     @default(false) @map("is_enabled")
  tierId         String      @map("tier_id")       // Package tier to auto-purchase
  threshold      Int         @default(100)          // Trigger when SMS remaining <= threshold
  maxPerMonth    Int         @default(3) @map("max_per_month") // Max auto purchases per month
  purchasedThisMonth Int     @default(0) @map("purchased_this_month")
  monthResetAt   DateTime    @default(now()) @map("month_reset_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  user           User        @relation(fields: [userId], references: [id])
  tier           PackageTier @relation(fields: [tierId], references: [id])

  @@map("auto_topup_settings")
}

// ══════════════════════════════════════════════════════════
// Package System (replaces Credit System)
// ══════════════════════════════════════════════════════════

model PackageTier {
  id              String            @id @default(cuid())
  name            String                                    // 'Starter', 'Basic', etc.
  tierCode        String            @unique @map("tier_code") // 'A', 'B', etc.
  price           Decimal           @db.Decimal(10, 2)      // ราคาไม่รวม VAT
  smsQuota        Int               @map("sms_quota")       // base SMS count
  bonusPercent    Int               @default(0) @map("bonus_percent")
  totalSms        Int               @map("total_sms")       // quota + bonus
  senderNameLimit Int?              @map("sender_name_limit") // NULL = unlimited
  expiryMonths    Int               @map("expiry_months")
  isActive        Boolean           @default(true) @map("is_active")
  isTrial         Boolean           @default(false) @map("is_trial")
  sortOrder       Int               @default(0) @map("sort_order")
  createdAt       DateTime          @default(now()) @map("created_at")
  purchases       PackagePurchase[]
  autoTopupSettings AutoTopupSetting[]
  payments        Payment[]
  orders          Order[]

  @@map("package_tiers")
}

model PackagePurchase {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String?       @map("organization_id")
  tierId         String        @map("tier_id")
  smsTotal       Int           @map("sms_total")           // total SMS (quota + bonus + promo)
  smsUsed        Int           @default(0) @map("sms_used")
  purchasedAt    DateTime      @default(now()) @map("purchased_at")
  expiresAt      DateTime      @map("expires_at")
  isActive       Boolean       @default(true) @map("is_active")
  transactionId  String?       @map("transaction_id")
  promotionId    String?       @map("promotion_id")
  couponId       String?       @map("coupon_id")
  autoRenew      Boolean       @default(false) @map("auto_renew")
  createdAt      DateTime      @default(now()) @map("created_at")
  tier           PackageTier   @relation(fields: [tierId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  promotion      Promotion?    @relation(fields: [promotionId], references: [id])
  coupon         Coupon?       @relation(fields: [couponId], references: [id])
  couponUsages   CouponUsage[]

  @@index([userId, isActive, expiresAt])
  @@index([organizationId, isActive])
  @@map("package_purchases")
}

model Promotion {
  id                  String            @id @default(cuid())
  name                String
  type                String                                 // 'bonus_boost', 'price_discount', 'extra_sender', 'extended_expiry'
  value               Decimal           @db.Decimal(10, 2)   // % or fixed amount
  applicableTiers     String[]          @map("applicable_tiers") // tier IDs
  startsAt            DateTime          @map("starts_at")
  endsAt              DateTime          @map("ends_at")
  maxRedemptions      Int?              @map("max_redemptions")
  currentRedemptions  Int               @default(0) @map("current_redemptions")
  isActive            Boolean           @default(true) @map("is_active")
  createdAt           DateTime          @default(now()) @map("created_at")
  purchases           PackagePurchase[]

  @@map("promotions")
}

model Coupon {
  id              String            @id @default(cuid())
  code            String            @unique
  discountType    String            @map("discount_type")    // 'percent', 'fixed', 'extra_sms', 'extra_sender'
  discountValue   Decimal           @map("discount_value") @db.Decimal(10, 2)
  minTier         String?           @map("min_tier")         // minimum tier code
  applicableTiers String[]          @map("applicable_tiers") // tier IDs
  usageLimit      Int?              @map("usage_limit")      // total uses
  perUserLimit    Int               @default(1) @map("per_user_limit")
  currentUsage    Int               @default(0) @map("current_usage")
  expiresAt       DateTime?         @map("expires_at")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  purchases       PackagePurchase[]
  usages          CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id         String          @id @default(cuid())
  couponId   String          @map("coupon_id")
  userId     String          @map("user_id")
  purchaseId String          @map("purchase_id")
  usedAt     DateTime        @default(now()) @map("used_at")
  coupon     Coupon          @relation(fields: [couponId], references: [id])
  user       User            @relation(fields: [userId], references: [id])
  purchase   PackagePurchase @relation(fields: [purchaseId], references: [id])

  @@index([couponId])
  @@index([userId, couponId])
  @@map("coupon_usages")
}

